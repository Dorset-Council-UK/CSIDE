@inherits LayoutComponentBase

<div class="page flex-row">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main class="flex-grow-1">
        <div class="top-row px-4">
            <div class="dropdown">
                <button class="btn btn-link dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false"><i class="bi bi-person-circle"><span class="visually-hidden">Your account</span></i></button>
                <ul class="dropdown-menu">
                    <li><h6 class="dropdown-header">User 123</h6></li>
                    <li><a class="dropdown-item" href="#">Manage application</a></li>
                    <li><a class="dropdown-item" href="#">Logout</a></li>
                </ul>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
