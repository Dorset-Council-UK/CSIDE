@rendermode InteractiveServer
@using CSIDE.Data.Models.DMMO
@using NodaTime
@using System.Globalization
@inject IDbContextFactory<ApplicationDbContext> contextFactory
@inject NavigationManager navigationManager

<a href="DMMO#search-form">@localizer["Search Again Label"]</a>

@if(DMMOApplications?.Count == MaxResults){
    <Alert Color="AlertColor.Warning">@localizer["Search Results Limit Text", MaxResults]</Alert>
}

<Grid TItem="Application"
Class="table table-hover table-bordered table-striped mt-2"
DataProvider="DMMOApplicationDataProvider"
AllowFiltering="true"
AllowPaging="true"
PageSize="20"
AllowSorting="true"
AllowSelection="false"
AllowRowClick="true"
OnRowClick="OnRowClick"
AutoHidePaging="true"
Responsive="true">

    <GridColumns>
        <GridColumn TItem="Application" Filterable="false" HeaderText="@localizer["Reference Number Label"]" PropertyName="Id" SortKeySelector="item => item.Id">
            <a href="DMMO/Details/@context.Id">@context.Id</a>
        </GridColumn>
        <GridColumn TItem="Application" Filterable="false" HeaderText="@localizer["Application Date Label"]" PropertyName="ApplicationDate" SortKeySelector="item => item.ApplicationDate">
            @(context.ApplicationDate.HasValue ? context.ApplicationDate.Value.ToString("dd/MM/yyyy", CultureInfo.CurrentCulture) : "Unknown")
        </GridColumn>
        <GridColumn TItem="Application" Filterable="false" HeaderText="@localizer["Received Date Label"]" PropertyName="ReceivedDate" SortKeySelector="item => item.ReceivedDate">
            @(context.ReceivedDate.HasValue ? context.ReceivedDate.Value.ToString("dd/MM/yyyy", CultureInfo.CurrentCulture) : "Unknown")
        </GridColumn>
        <GridColumn TItem="Application" Class="comment-field" Sortable="false" HeaderText="@localizer["Application Details Label"]" PropertyName="ApplicationDetails" SortKeySelector="item => item.ApplicationDetails">
            @if(context.ApplicationDetails.Length > 200){
                @context.ApplicationDetails.Substring(0, 200)

                <text>&hellip;</text>
            }else{
                @context.ApplicationDetails
            }

        </GridColumn>
        <GridColumn TItem="Application" Filterable="false" HeaderText="@localizer["Parish Label"]" PropertyName="JobPriority" SortKeySelector="@(item => item.DMMOParishes != null ? string.Join(", ", item.DMMOParishes.Select(p => p.Parish.Name)) : string.Empty)">
            @string.Join(", ", context.DMMOParishes.Select(p => p.Parish.Name))
        </GridColumn>
        <GridColumn TItem="Application" Filterable="false" HeaderText="@localizer["Case Status Label"]" PropertyName="CaseStatus" SortKeySelector="item => item.CaseStatus != null ? item.CaseStatus.Name : string.Empty">
            @context.CaseStatus?.Name
        </GridColumn>
    </GridColumns>
    <GridTemplates>
        <GridEmptyDataTemplate TItem="Application">
            <div class="text-center text-muted">
                <span class="bi bi-inbox fs-2"></span>
                <div>
                    <p>@localizer["No Results Found Label"]</p>
                    <p><a href="DMMO#search-form">@localizer["Search Again Label"]</a></p>
                </div>
            </div>
        </GridEmptyDataTemplate>
    </GridTemplates>
</Grid>


@code {
    [Parameter]
    public required List<Application> DMMOApplications { get; set; }
    [Parameter]
    public int MaxResults { get; set; }

    private async Task<GridDataProviderResult<Application>> DMMOApplicationDataProvider(GridDataProviderRequest<Application> request)
    {
        var result = await Task.FromResult(request.ApplyTo(DMMOApplications));
        return result;
    }

    private void OnRowClick(GridRowEventArgs<Application> args) => navigationManager.NavigateTo($"DMMO/Details/{args.Item.Id}");
}