@using CSIDE.Options
@using Microsoft.Extensions.Options

@inject IOptions<CSIDEOptions> CsideOptions

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/@(_csideOptions.PathBase)" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="_content/Blazor.Bootstrap/blazor.bootstrap.css" rel="stylesheet" />
    
    <link rel="stylesheet" href="@Assets["lib/openlayers/ol.css"]" />
    <link rel="stylesheet" href="@Assets["lib/ol-ext/ol-ext.css"]" />
    <link rel="stylesheet" href="@Assets["lib/blueimp-gallery/blueimp-gallery.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["CSIDE.styles.css"]" />
    <link rel="icon" href="@IconsRoot/favicon.ico" sizes="32x32" />
    <link rel="icon" href="@IconsRoot/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="@IconsRoot/apple-touch-icon.png" />
    @if (!string.IsNullOrEmpty(IconsRoot))
    {
        <link rel="manifest" href="@IconsRoot/manifest.webmanifest" />
    }
    <style type="text/css">
        :root{
            --primary-color: @(_csideOptions.Theme.PrimaryColour);
            --primary-color-dark: color-mix(in srgb, var(--primary-color), black 25%);
        }
    </style>
    <HeadOutlet @rendermode="@InteractiveServer" />
</head>

<body>
    <Routes @rendermode="@InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
    <script src="_content/Blazor.Bootstrap/blazor.bootstrap.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
@*  <script src="@Assets["lib/openlayers/proj4.js"]"></script>
    <script src="@Assets["lib/openlayers/ol.js"]"></script>
    <script src="@Assets["lib/ol-ext/ol-ext.min.js"]"></script> *@
    <script src="@Assets["lib/blueimp-gallery/blueimp-gallery.min.js"]"></script>
</body>

</html>

@code {
    private CSIDEOptions _csideOptions => CsideOptions.Value;
    private string IconsRoot => _csideOptions.Theme.IconsRoot;
}
