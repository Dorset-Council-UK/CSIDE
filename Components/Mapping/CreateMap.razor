@inject IJSRuntime JS
@implements IAsyncDisposable
@using CSIDE.Data.Models.Shared
@using NetTopologySuite.Geometries
@using NetTopologySuite.IO
@using System.Text.Json
@using System.Text.Json.Serialization
@inject IConfiguration config;

<div id="@MapId" class="" style="width:100%;height:400px"></div>

@code {
    [Parameter]
    public string GeomType{ get; set; }
    [Parameter] 
    public EventCallback<string> OnDrawEndMethod { get; set; }

    private string MapId = $"create-map-{new Random().Next()}";

    private IJSObjectReference? _jsModule;
    private DotNetObjectReference<CreateMap>? self;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            self ??= DotNetObjectReference.Create(this);
            _jsModule ??= await JS.InvokeAsync<IJSObjectReference>(
                "import", "/Components/Mapping/CreateMap.razor.js");

            var mappingConfig = config.GetSection("CSIDE:Mapping");
            var boundsConfig = mappingConfig.GetSection("StartBounds");
            var routeOverlay = new OverlayConfiguration() { MapServiceBaseURL = mappingConfig.GetValue<string>("MapServerRoot")!, LayerName = mappingConfig.GetValue<string>("RouteLayer") };
            var mapConfigClass = new MapConfiguration() { 
                    MapId = MapId,
                    OSMapsAPIKey = mappingConfig.GetValue<string>("OSMapsAPIKey")!,
                    OSLicenceNumber = mappingConfig.GetValue<string>("OSLicenceNumber")!,
                    Basemap = BasemapLayer.Outdoor, 
                    Bounds = [boundsConfig.GetValue<double>("MinX"), boundsConfig.GetValue<double>("MinY"), boundsConfig.GetValue<double>("MaxX"), boundsConfig.GetValue<double>("MaxY")],
                    Overlays = [routeOverlay]
            };
            JsonSerializerOptions opts = new(JsonSerializerDefaults.Web);
            opts.Converters.Add(new JsonStringEnumConverter());
            var mapConfigJson = JsonSerializer.Serialize(mapConfigClass, opts);

            await _jsModule.InvokeVoidAsync("initMap", GeomType, mapConfigJson, self);
        }
        await base.OnAfterRenderAsync(firstRender);
    }


    [JSInvokable]
    public void OnDrawEnd(string features)
    {
        OnDrawEndMethod.InvokeAsync(features);
        //check validity of features
    }

    public async Task ClearDrawnGeometries()
    {
        await _jsModule!.InvokeVoidAsync("clearDrawnGeometries");
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        if (_jsModule is not null)
        {
            await _jsModule.DisposeAsync();
        }
    }
}
