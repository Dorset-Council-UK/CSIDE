@page "/Infrastructure/Items"
@using CSIDE.Components.Infrastructure
@inject IStringLocalizer<Properties.Resources> localizer

<PageTitle>@localizer["Search Results Title"]</PageTitle>

<div>
    <Breadcrumb Items="NavItems"></Breadcrumb>
</div>

<h1>@localizer["Search Results Title"]</h1>

@if (IsBusy)
{
    <p class="fs-4">
        <div class="spinner-border" role="status"></div> @localizer["Loading Text"]
    </p>
}

@if(SearchResults is not null)
{
    <InfrastructureItemsList InfrastructureItems="@SearchResults" MaxResults="@MaxResults"></InfrastructureItemsList>    
}
