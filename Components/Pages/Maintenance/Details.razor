@page "/Maintenance/Details/{JobId:int}"
@using CSIDE.Data.Models.Maintenance
@using CSIDE.Components.Maintenance
@using CSIDE.Components.Mapping
@using CSIDE.Components.Layout
@using System.Globalization
@using CSIDE.Data.Models.Shared
@inject IDbContextFactory<ApplicationDbContext> contextFactory
@inject NavigationManager navigationManager


<div>
    <Breadcrumb Items="NavItems"></Breadcrumb>
</div>

@if (IsBusy)
{
    <PageTitle>@localizer["Loading Text"]</PageTitle>
    <p class="fs-4">
        <div class="spinner-border" role="status"></div> @localizer["Loading Text"]
    </p>
}

@if (Job is null && !IsBusy)
{
    <PageTitle>@localizer["Maintenance Job Not Found Error Message", JobId]</PageTitle>
    <Alert Color="AlertColor.Danger">@localizer["Maintenance Job Not Found Error Message",JobId]</Alert>
}
else
{
    if(Job is not null){
        <PageTitle>@localizer["Maintenance Details Title", Job.Id]</PageTitle>
        <h1>@localizer["Maintenance Details Title", Job.Id]</h1>

        <a href="Maintenance/Edit/@Job.Id" class="btn btn-primary my-2">@localizer["Edit Label"]</a>

        <div class="row">
            <div class="col-lg-8">

                <CollapsibleCard Id="maint-basic-details" Title="@localizer["Basic Details Label"]" IsShownByDefault="true">
                    <ChildContent>
                        <ErrorBoundary>
                            <ChildContent>
                        
                                <table class="table table-striped">
                                    <tbody>
                                        <tr>
                                            <th class="w-25">@localizer["Job ID Label"]</th>
                                            <td>@Job.Id</td>
                                        </tr>
                                        <tr>
                                            <th>@localizer["Log Date Label"]</th>
                                            <td>@(Job.LogDate.HasValue ? Job.LogDate.Value.ToString("dd/MM/yyyy HH:mm", CultureInfo.CurrentCulture) : "Unknown")</td>
                                        </tr>
                                        <tr>
                                            <th>@localizer["Logged By Label"]</th>
                                            <td>@Job.LoggedByName</td>
                                        </tr>
                                        <tr>
                                            <th>@localizer["Problem Description Label"]</th>
                                            <td class="text-break comment-field">@Job.ProblemDescription</td>
                                        </tr>
                                        <tr>
                                            <th>@localizer["Problem Types Label"]</th>
                                            <td>
                                                @if (Job.ProblemTypes.Count != 0)
                                                {
                                                    <ul class="list-unstyled">
                                                    @foreach(var problem in Job.ProblemTypes){
                                                        <li>@problem.ProblemType?.Name</li>
                                                    }
                                                    </ul>
                                                }
                                            </td>
                                        </tr>
                                        <tr>
                                            <th>@localizer["Assigned To Team Label"]</th>
                                            <td>@Job.MaintenanceTeam?.Name</td>
                                        </tr>
                                        <tr>
                                            <th>@localizer["Route ID Label"]</th>
                                            <td>@Job.RouteId</td>
                                        </tr>
                                        <tr>
                                        <th>@localizer["Parish Label"]</th>
                                            <td>@Job.Parish?.Name</td>
                                        </tr>
                                        <tr>
                                            <th>@localizer["Job Priority Label"]</th>
                                            <td>@Job.JobPriority?.Description</td>
                                        </tr>
                                        <tr>
                                            <th>@localizer["Job Status Label"]</th>
                                            <td>@Job.JobStatus?.Description</td>
                                        </tr>
                                        @if (Job.DuplicateJobId is not null){
                                            <tr>
                                                <th>@localizer["Duplicate Job ID Label"]</th>
                                                <td><a href="Maintenance/Details/@Job.DuplicateJobId">@Job.DuplicateJobId</a></td>
                                            </tr>
                                        }
                                        <tr>
                                            <th>@localizer["Completion Date Label"]</th>
                                            <td>@Job.CompletionDate</td>
                                        </tr>
                                        <tr>
                                            <th>@localizer["Work Done Label"]</th>
                                            <td class="text-break">@Job.WorkDone</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </ChildContent>
                            <ErrorContent Context="Exception">
                                <GenericErrorAlert Exception="Exception"></GenericErrorAlert>
                            </ErrorContent>
                        </ErrorBoundary>
                    </ChildContent>
                </CollapsibleCard>

                <CollapsibleCard Id="maint-comments" Title="@localizer["Comments Label",Job.Comments.Count]">
                    <ChildContent>
                        <ErrorBoundary>
                            <ChildContent>
                                <CommentsList Job="@Job" IsEditable="UserCanEdit"></CommentsList>
                            </ChildContent>
                            <ErrorContent Context="Exception">
                                <GenericErrorAlert Exception="Exception"></GenericErrorAlert>
                            </ErrorContent>
                        </ErrorBoundary>
                    </ChildContent>
                </CollapsibleCard>

                <CollapsibleCard Id="maint-contacts" Title="@localizer["Contacts Label",Job.JobContacts.Count]">
                    <ChildContent>
                        <ErrorBoundary>
                            <ChildContent>
                                <ContactsList 
                                    Contacts="@Job.JobContacts.Select(c => c.Contact).ToArray()" 
                                    IsEditable="UserCanEdit" 
                                    OnSubmit="AddContact"
                                    OnRefresh="RefreshContactsList"></ContactsList>
                            </ChildContent>
                            <ErrorContent Context="Exception">
                                <GenericErrorAlert Exception="Exception"></GenericErrorAlert>
                            </ErrorContent>
                        </ErrorBoundary>
                    </ChildContent>
                </CollapsibleCard>

                <CollapsibleCard Id="maint-infrastructure" Title="@localizer["Infrastructure With Count Title",Job.JobInfrastructure.Count]">
                    <ChildContent>
                        <ErrorBoundary>
                            <ChildContent>
                                <InfrastructureList JobInfrastructure="@Job.JobInfrastructure" JobId="@JobId" IsEditable="true"></InfrastructureList>
                            </ChildContent>
                            <ErrorContent Context="Exception">
                                <GenericErrorAlert Exception="Exception"></GenericErrorAlert>
                            </ErrorContent>
                        </ErrorBoundary>
                    </ChildContent>
                </CollapsibleCard>

                <CollapsibleCard Id="maint-media" Title="@localizer["Media Label",Job.JobMedia.Count]">
                    <ChildContent>
                        <ErrorBoundary>
                            <ChildContent>
                                <MediaList Job="@Job" IsEditable="UserCanEdit"></MediaList>
                            </ChildContent>
                            <ErrorContent Context="Exception">
                                <GenericErrorAlert Exception="Exception"></GenericErrorAlert>
                            </ErrorContent>
                        </ErrorBoundary>
                    </ChildContent>
                </CollapsibleCard>

                <CollapsibleCard Id="maint-audit" Title="@localizer["Audit Log Title"]">
                    <ChildContent>
                        <ErrorBoundary>
                            <ChildContent>
                                <AuditLogList SectionNames="@AuditLogSectionNames" EntityId="@Job.Id.ToString()"></AuditLogList>
                            </ChildContent>
                            <ErrorContent Context="Exception">
                                <GenericErrorAlert Exception="Exception"></GenericErrorAlert>
                            </ErrorContent>
                        </ErrorBoundary>
                    </ChildContent>
                </CollapsibleCard>

            </div>
            <div class="col-lg-4">
                <ErrorBoundary>
                    <ChildContent>
                        @if (Job.Geom is not null)
                        {
                            <MiniMap Geometry="@Job.Geom"></MiniMap>
                        }
                        <table class="table table-striped table-sm">
                            <tbody>
                                <tr><th>@localizer["Easting Label"]</th><td>@Convert.ToInt32(Job.Geom?.X)</td></tr>
                                <tr><th>@localizer["Northing Label"]</th><td>@Convert.ToInt32(Job.Geom?.Y)</td></tr>
                            </tbody>
                        </table>
                    </ChildContent>
                    <ErrorContent Context="Exception">
                        <GenericErrorAlert Exception="Exception"></GenericErrorAlert>
                    </ErrorContent>
                </ErrorBoundary>
            </div>
        </div>
    }
}
@code {
    private List<BreadcrumbItem>? NavItems;

    [Parameter]
    public int JobId{ get; set; }
    private Job? Job { get; set; }

    private bool IsBusy{ get; set; }

    [CascadingParameter]
    private Task<AuthenticationState>? authenticationState { get; set; }

    private bool UserCanEdit { get; set; } = false;

    private string[] AuditLogSectionNames => new string[] {
        nameof(Data.Models.Maintenance.Job),
        nameof(Data.Models.Maintenance.Comment),
        nameof(Data.Models.Maintenance.JobContact),
        nameof(Data.Models.Maintenance.JobInfrastructure),
        nameof(Data.Models.Maintenance.JobMedia),
        nameof(Data.Models.Maintenance.JobProblemType)
    };

    protected override async Task OnParametersSetAsync()
    {
        NavItems = new List<BreadcrumbItem>
        {
            new BreadcrumbItem{ Text = localizer["Home Title"], Href ="/" },
            new BreadcrumbItem{ Text = localizer["Maintenance Title"], Href="Maintenance" },
            new BreadcrumbItem{ Text = localizer["Maintenance Details Title", JobId], IsCurrentPage = true }
        };

        IsBusy = true;
        try
        {
            using var context = contextFactory.CreateDbContext();
            Job = await context.MaintenanceJobs.FindAsync(JobId);
        }
        finally
        {
            IsBusy = false;
        }

        //check user has permission to edit
        if (authenticationState is not null)
        {
            var authState = await authenticationState;
            var user = authState?.User;
            if (user is not null)
            {
                UserCanEdit = user.IsInRole("Administrator") || user.IsInRole("RoW Officer") || user.IsInRole("Ranger");
            }
        }
    }
    private async Task AddContact(Contact NewContact){
        
        if (NewContact is not null && Job is not null)
        {
            using var context = contextFactory.CreateDbContext();

            context.Contacts.Add(NewContact);
            await context.SaveChangesAsync();
            context.MaintenanceJobContact.Add(new JobContact { ContactId = NewContact.Id, JobId = Job.Id }); //UHRMMMM?
            await context.SaveChangesAsync();
        } 
    }
    private async Task RefreshContactsList()
    {
        using var context = contextFactory.CreateDbContext();
        Job = await context.MaintenanceJobs.FindAsync(JobId);
        StateHasChanged();
    }
}
