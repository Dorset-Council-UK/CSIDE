@page "/management/auditlog"
@using CSIDE.Components.Pages.Account

<AuthorizeView Roles="Administrator">
    <NotAuthorized>
        <AccessDenied></AccessDenied>
    </NotAuthorized>
    <Authorized>
        <PageTitle>@localizer["Audit Log Title"]</PageTitle>
        <div>
            <Breadcrumb Items="NavItems"></Breadcrumb>
        </div>


        <h1>@localizer["Audit Log Title"]</h1>

        <AuditLogList></AuditLogList>
    </Authorized>
</AuthorizeView>

@code{
    private List<BreadcrumbItem>? NavItems;

    protected override void OnInitialized()
    {
        NavItems = new List<BreadcrumbItem>
        {
            new BreadcrumbItem { Text = localizer["Home"], Href = "" },
            new BreadcrumbItem { Text = localizer["Management Title"], Href = "management" },
            new BreadcrumbItem { Text = localizer["Audit Log Title"], Href = "management/auditlog", IsCurrentPage = true }
        };
    }
}
