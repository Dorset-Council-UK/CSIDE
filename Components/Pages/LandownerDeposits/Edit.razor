@page "/landowner-deposits/Edit/{LandownerDepositId:int}"
@using CSIDE.Components.LandownerDeposits
@using CSIDE.Data.Models.LandownerDeposits
@using CSIDE.Components.Mapping
@using NodaTime
@using System.Globalization
@inject IStringLocalizer<CSIDE.Properties.Resources> localizer

<PageTitle>@localizer["Landowner Deposit Edit Title", LandownerDepositId]</PageTitle>

<div>
    <Breadcrumb Items="NavItems"></Breadcrumb>
</div>

<h1>@localizer["Landowner Deposit Edit Title", LandownerDepositId]</h1>

@if (LandownerDeposit is null && !IsBusy)
{
    <Alert Color="AlertColor.Danger">@localizer["Landowner Deposit Not Found Error Message", LandownerDepositId]</Alert>
    <a href="landowner-deposits" class="btn btn-primary">@localizer["Search Landowner Deposits Title"]</a>
}
else
{
    if (ErrorMessage is not null)
    {
        <Alert Color="AlertColor.Danger">@ErrorMessage</Alert>
    }

    if (LandownerDeposit is not null)
    {
        <div class="row">
            <EditMap @ref="@editMap" OnDrawEndMethod="ValidateGeometry" GeomType="Polygon" Geometry="@LandownerDeposit.Geom"></EditMap>
        </div>
        @if (!GeometryIsValid)
        {
            <Alert Color="AlertColor.Danger">@localizer["Invalid Geometry Validation Message"]</Alert>
        }
    }
   
    <div class="row mt-2">
        <div class="col-md-8">
            <LandownerDepositEditForm 
                LandownerDeposit="@LandownerDeposit"
                LandownerDepositTypeNames="@LandownerDepositTypeNames"
                SelectedLandownerDepositTypes="@SelectedLandownerDepositTypes"
                IsBusy="@IsBusy"
                IsEdit="@true"
                OnSubmit="SubmitFormAsync"
                OnCancel="NavigateBackToLandownerDepositDetailsPage"
                @ref="childLandownerDepositEditForm" />
        </div>
    </div>

    if (ErrorMessage is not null)
    {
        <Alert Color="AlertColor.Danger" Class="mt-2">@ErrorMessage</Alert>
    }

    @*TODO - These are duplicated in Edit.razor - Componentize them? Or make it part of the EditForm?*@
    <Modal @ref="routeValidationModal" Title="@localizer["Error Title"]">
        <BodyTemplate>
            @localizer["No Rights of Way Near Geometry Validation Message"]<br />
            @localizer["No Rights of Way Near Geometry Options Text"]
        </BodyTemplate>
        <FooterTemplate>
            <Button Color="ButtonColor.Secondary" @onclick="HideRouteValidationModal">@localizer["Route ID Manual Entry Label"]</Button>
            <Button Color="ButtonColor.Primary" @onclick="ClearDrawnGeometries">@localizer["Redraw Label"]</Button>
        </FooterTemplate>

    </Modal>

    <Modal @ref="errorModal" Title="@localizer["Error Title"]">
        <BodyTemplate>
            @localizer["Invalid Geometry Validation Message"]
        </BodyTemplate>
        <FooterTemplate>
            <Button Color="ButtonColor.Primary" @onclick="ClearDrawnGeometries">@localizer["Redraw Label"]</Button>
        </FooterTemplate>
    </Modal>
}
