@page "/"
@using CSIDE.Options
@using Microsoft.Extensions.Options

@inject IOptions<CSIDEOptions> CsideOptions

<PageTitle>@localizer["Home Title"]</PageTitle>

<h1>@localizer["Welcome Text", _csideOptions.AppName]</h1>


<div class="container-fluid g-0 mt-4">
    <div class="row justify-content-start row-cols-1 row-cols-md-2 row-cols-xl-3 g-4 ">
    <AuthorizeView Roles="Administrator, Ranger">
        <div class="col">
            <RecentMaintenanceJobsCard></RecentMaintenanceJobsCard>
        </div>
    </AuthorizeView>
    <div class="col">
        <MyWorkCard></MyWorkCard>
    </div>
    </div>
</div>





@code {
    private CSIDEOptions _csideOptions => CsideOptions.Value;
}