@page "/surveys/bridge/new"
@using System.Globalization
@using CSIDE.Components.Authorization

<div>
    <Breadcrumb Items="NavItems"></Breadcrumb>
</div>

<PageTitle>@localizer["New Bridge Survey Title"]</PageTitle>

<AuthorizeView Roles="Surveyor, Ranger, Administrator">
    <NotAuthorized>
        <AccessDenied></AccessDenied>
    </NotAuthorized>
    <Authorized>
        <h1>@localizer["Find Bridge Survey Title"]</h1>

        <p>@localizer["New Bridge Survey Help Text"]</p>

        <h2 class="mb-3">@localizer["Find Bridge By ID Title"]</h2>

        <form method="post" @onsubmit="@OnInfrastructureIDSearchSubmit" @formname="InfrastructureIDSearch" class="mt-3">
            @if (InfrastructureIDSearchErrorMessage is not null)
            {
                <Alert Color="AlertColor.Danger">@InfrastructureIDSearchErrorMessage</Alert>
            }
            <div class="row">
                <div class="col-sm-6 col-lg-4">
                    <label class="form-label" for="infrastructure-id-search">@localizer["Infrastructure ID Label"]</label>
                    <div class="input-group mb-3">
                        @if (!string.IsNullOrEmpty(IDPrefixOptions.Value.Infrastructure))
                        {
                            <span class="input-group-text" id="infrastructure-id-prefix">@IDPrefixOptions.Value.Infrastructure</span>
                        }
                        <InputText id="infrastructure-id-search" @bind-Value="InfrastructureIDSearch" class="form-control"></InputText>
                        <button class="btn btn-outline-secondary" type="submit" id="search-infrastructure-id-button" disabled="@IsBusy">@localizer["Search Label"]</button>
                    </div>
                </div>
            </div>
        </form>

        <hr />

        <h2 class="mb-3">@localizer["Find Bridge By Location Title"]</h2>
        <p>@localizer["Find Bridge By Location Text"]</p>

        @if (LocationFetchErrrorMessage is not null)
        {
            <Alert Color="AlertColor.Danger">@LocationFetchErrrorMessage</Alert>
        }
        <Button Color="ButtonColor.Primary" Outline="true" Type="ButtonType.Button" disabled="@(IsBusy || IsLocating)" Class="mb-2" @onclick="OnLocationRequest">
            <Spinner Type="SpinnerType.Grow" Visible="@IsLocating" Size="SpinnerSize.Small"></Spinner> @(IsLocating ? localizer["Locating Label"] : @localizer["Locate Me Label"])
        </Button>

        @if (IsLocating && LocationAccuracy is not null)
        {
            <p>@localizer["Bridge Survey Confirm Location Current Accuracy Label", LocationAccuracy]</p>
        }
        @if (NearbyBridges is not null && NearbyBridges.Count != 0)
        {
            <p>@localizer["Bridges Found Text", NearbyBridges.Count]</p>
            <ul>
                @foreach (var NearbyBridge in NearbyBridges)
                {
                    <li>
                        <a href="surveys/bridge/start/@NearbyBridge.Bridge.Id">@NearbyBridge.Bridge.Id</a> (@localizer["X Metres Away Label", Math.Round(NearbyBridge.Distance)])
                    </li>
                }
            </ul>
        }

        @if (!string.IsNullOrEmpty(MappingOptions.ExternalMappingSystemBridgeSurveyMapURL))
        {
            <hr />
            <h2>@localizer["Find Bridge On Map Title"]</h2>
            <iframe src="@MappingOptions.ExternalMappingSystemBridgeSurveyMapURL" width="100%" height="400px"></iframe>
        }
    </Authorized>
</AuthorizeView>





