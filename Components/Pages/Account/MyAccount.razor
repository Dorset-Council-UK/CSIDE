@page "/Account/MyAccount"
@inject IDbContextFactory<ApplicationDbContext> ContextFactory;
@inject IStringLocalizer<CSIDE.Properties.Resources> localizer

<PageTitle>@localizer["My Account Label"]</PageTitle>

<h3>@localizer["My Account Label"]</h3>

<p>@localizer["Account Details Text"]</p>

<table class="table table-striped">
    <tr><th>@localizer["Display Name Label"]</th><td>@UserDisplayName</td></tr>
    <tr><th>@localizer["Email Label"]</th><td>@UserPrimaryEmailAddress</td></tr>
    <tr><th>@localizer["User ID Label"]</th><td>@UserID</td></tr>
</table>

<h3>@localizer["My Roles Header"]</h3>

@if(ApplicationRoles is null){
    <p>@localizer["Loading Text"]</p>
}else{
    if(ApplicationRoles.Count == 0)
    {
        <p>@localizer["No Roles Text"]</p>
    }
    else
    {
        <p>@localizer["Roles List Text"]</p>
        <ul>
            @foreach (var role in ApplicationRoles)
            {
                <li>@role.RoleName</li>
            }
        </ul>
    }
}

@code {
    [CascadingParameter]
    private Task<AuthenticationState> authenticationStateTask { get; set; }

    private string? UserID{ get; set; }
    private string? UserDisplayName{ get; set; }
    private string? UserPrimaryEmailAddress { get; set; }
    private List<ApplicationRole>? ApplicationRoles { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = ContextFactory.CreateDbContext();

        var user = (await authenticationStateTask).User;
        UserID = user.FindFirst(u => u.Type.Contains("nameidentifier"))?.Value;
        UserDisplayName = user.Identity?.Name;
        UserPrimaryEmailAddress = user.FindFirst(u => u.Type.Contains("email"))?.Value;

        var userRoles = await context.ApplicationUserRoles
                .Where(u => u.UserId == UserID)
                .Include(a => a.Role)
                .AsNoTrackingWithIdentityResolution()
                .ToListAsync();

        ApplicationRoles = userRoles.Select(r => r.Role).ToList();

    }
}