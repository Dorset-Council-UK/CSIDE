@page "/rights-of-way/List"
@using CSIDE.Components.RightsOfWay

<PageTitle>@localizer["Search Results Title"]</PageTitle>

<div>
    <Breadcrumb Items="NavItems"></Breadcrumb>
</div>

<h1>@localizer["Search Results Title"]</h1>

@if (IsBusy)
{
    <p class="fs-4">
        <div class="spinner-border" role="status"></div> @localizer["Loading Text"]
    </p>
}

@if (SearchResults is not null)
{
    <RoutesList Routes="@SearchResults" MaxResults="@MaxResults"></RoutesList>
}
