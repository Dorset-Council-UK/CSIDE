@using CSIDE.Data.Models.Maintenance
@using CSIDE.Data.Models.Shared
@using System.Globalization
@inject IDbContextFactory<ApplicationDbContext> contextFactory
@inject IJSRuntime JS
@implements IAsyncDisposable

@if(Job is not null)
{
    
    @if (Job.JobMedia is not null && Job.JobMedia.Count != 0)
    {
        
        var images = from m in Job.JobMedia where m.Media.Format == MediaType.Image select m;
        var videos = from m in Job.JobMedia where m.Media.Format == MediaType.Video select m;
        var docs = 
            from m in Job.JobMedia where (
                m.Media.Format == MediaType.PDF_Document | 
                m.Media.Format == MediaType.Word_Document |
                m.Media.Format == MediaType.Excel_Spreadsheet |
                m.Media.Format == MediaType.Unknown)
            select m;

        if (images.Count() != 0)
        {
            <div class="row my-4">
                <h4>@localizer["Images Label"]</h4>
                <div id="media-gallery">
                    @foreach (JobMedia jobMediaItem in images.OrderByDescending(i => i.Media.UploadDate))
                    {
                        <MediaItem Media="@jobMediaItem.Media" IsEditable="@IsEditable" OnRefreshComponent="RefreshComponent"></MediaItem>
                    }
                </div>
                
            </div>
            <hr/>
        }
        if (videos.Count() != 0)
        {
            <div class="row my-4">
                <h4>@localizer["Videos Label"]</h4>
                @foreach (JobMedia jobMediaItem in videos.OrderByDescending(i => i.Media.UploadDate))
                {
                    <div class="col-12">
                        <MediaItem Media="@jobMediaItem.Media" IsEditable="@IsEditable" OnRefreshComponent="RefreshComponent"></MediaItem>
                    </div>
                }
            </div>
            <hr />
        }

        if (docs.Count() != 0)
        {
            <div class="row my-4">
                <h4>@localizer["Documents Label"]</h4>
                <div class="col">
                    <table class="table table-striped">
                        <tbody>
                            @foreach (JobMedia jobMediaItem in docs.OrderByDescending(i => i.Media.UploadDate))
                        {
                            <MediaItem Media="@jobMediaItem.Media" IsEditable="@IsEditable" OnRefreshComponent="RefreshComponent"></MediaItem>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
    else
    {
        <Alert Color="AlertColor.Info">@localizer["No Media Message"]</Alert>
    }
}

@if (IsEditable)
{
    <UploadFile 
        MaxAllowedFiles="10" 
        MaxFileSizeMB="50" 
        OnUploadComplete="@AddMediaToJob" 
        UploadErrorMessages="@UploadErrorMessages" 
        UploadSuccessMessage="@UploadSuccessMessage">
    </UploadFile>
}

<!--lightbox-->
<div id="blueimp-gallery"
class="blueimp-gallery blueimp-gallery-controls"
aria-label="image gallery"
aria-modal="true"
role="dialog">
    <div class="slides" aria-live="polite"></div>
    <h3 class="title"></h3>
    <a class="prev"
    aria-controls="blueimp-gallery"
    aria-label="previous slide"
    aria-keyshortcuts="ArrowLeft"></a>
    <a class="next"
    aria-controls="blueimp-gallery"
    aria-label="next slide"
    aria-keyshortcuts="ArrowRight"></a>
    <a class="close"
    aria-controls="blueimp-gallery"
    aria-label="close"
    aria-keyshortcuts="Escape"></a>
    <a class="play-pause"
    aria-controls="blueimp-gallery"
    aria-label="play slideshow"
    aria-keyshortcuts="Space"
    aria-pressed="false"
    role="button"></a>
    <ol class="indicator"></ol>
</div>

@code {
    [Parameter]
    public Job? Job{ get; set; }
    [Parameter]
    public bool IsEditable{ get; set; }


    private bool IsBusy { get; set; }
    private bool IsEditing { get; set; }
    private string? ErrorMessage { get; set; }
    private string? UploadSuccessMessage{ get; set; }
    private List<string> UploadErrorMessages { get; set; } = [];
    private IJSObjectReference? _jsModule;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        _jsModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "/Components/Maintenance/MediaList.razor.js");

        await _jsModule.InvokeVoidAsync("initGallery");

        await base.OnAfterRenderAsync(firstRender);
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        if (_jsModule is not null)
        {
            await _jsModule.DisposeAsync();
        }
    }

    private async Task AddMediaToJob(List<Media> UploadedMedia)
    {
        UploadSuccessMessage = null;
        if (Job is not null && UploadedMedia.Count != 0)
        {
            using var context = contextFactory.CreateDbContext();
            context.Attach(Job);
            foreach (Media media in UploadedMedia)
            {
                Job.JobMedia.Add(new JobMedia
                    {
                        JobId = Job.Id,
                        Media = media
                    });
            }
            await context.SaveChangesAsync();
            UploadSuccessMessage = localizer["Upload Success Message", UploadedMedia.Count];
            //await RefreshComponent();
        }
    }

    private async Task RefreshComponent()
    {
        if (Job is not null)
        {
            using var context = contextFactory.CreateDbContext();
            Job = await context.MaintenanceJobs.FindAsync([Job.Id]);
            ErrorMessage = null;
            UploadErrorMessages = [];
            StateHasChanged();
        }
    }
}
