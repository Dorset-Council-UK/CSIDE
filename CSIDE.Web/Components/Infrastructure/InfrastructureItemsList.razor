@rendermode InteractiveServer
@using CSIDE.Data.Models.Infrastructure
@using CSIDE.Data.Services
@using System.ComponentModel
@inject NavigationManager navigationManager
@inject IInfrastructureService infrastructureService

<a href="Infrastructure#search-form">@localizer["Search Again Label"]</a>

<Grid TItem="InfrastructureItem"
        Class="table table-hover table-bordered table-striped mt-2"
        DataProvider="InfrastructureItemsDataProvider"
        AllowFiltering="false"
        AllowPaging="true"
        PageSize="20"
        AllowSorting="true"
        AllowSelection="false"
        AllowRowClick="true"
        OnRowClick="OnRowClick"
        AutoHidePaging="true"
        Responsive="true">

    <GridColumns>
        <GridColumn TItem="InfrastructureItem" HeaderText="@localizer["Infrastructure ID Label"]" PropertyName="Id" SortKeySelector="item => item.Id" SortString="Id">
            <a href="Infrastructure/Details/@context.Id">@IDPrefixOptions.Value.Infrastructure@context.Id</a>
        </GridColumn>
        <GridColumn TItem="InfrastructureItem" HeaderText="@localizer["Parish Label"]" PropertyName="Parish" SortKeySelector="item => item.Parish != null ? item.Parish.Name : string.Empty" SortString="Parish">
            @context.Parish?.Name
        </GridColumn>
        <GridColumn TItem="InfrastructureItem" HeaderText="@localizer["Route ID Label"]" PropertyName="RouteId" SortKeySelector="item => item.RouteId" SortString="RouteId">
            @context.RouteId
        </GridColumn>
        <GridColumn TItem="InfrastructureItem" HeaderText="@localizer["Infrastructure Type Label"]" PropertyName="InfrastructureType" SortKeySelector="item => item.InfrastructureType != null ? item.InfrastructureType.Name : string.Empty" SortString="InfrastructureType">
            @context.InfrastructureType?.Name
        </GridColumn>

    </GridColumns>
    <GridTemplates>
        <GridEmptyDataTemplate TItem="InfrastructureItem">
            <div class="text-center text-muted">
                <span class="bi bi-inbox fs-2"></span>
                <div>
                    <p>@localizer["No Results Found Label"]</p>
                    <p><a href="Infrastructure#search-form">@localizer["Search Again Label"]</a></p>
                </div>
            </div>
        </GridEmptyDataTemplate>
    </GridTemplates>
</Grid>



@code {
    [Parameter]
    public string? RouteId { get; set; }
    [Parameter]
    public string[]? ParishIds { get; set; }
    [Parameter]
    public string? ParishId { get; set; }
    [Parameter]
    public string? MaintenanceTeamId { get; set; }
    [Parameter]
    public string? LoggedById { get; set; }
    [Parameter]
    public string? InfrastructureTypeId { get; set; }
    [Parameter]
    public DateOnly? InstallationDateFrom { get; set; }
    [Parameter]
    public DateOnly? InstallationDateTo { get; set; }


    public async Task<GridDataProviderResult<InfrastructureItem>> InfrastructureItemsDataProvider(GridDataProviderRequest<InfrastructureItem> request)
    {
        //handle sorting
        string sortString = "";
        ListSortDirection sortDirection = ListSortDirection.Ascending;
        if (request.Sorting is not null && request.Sorting.Any())
        {
            // Note: Multi column sorting is not supported at this moment
            sortString = request.Sorting.FirstOrDefault()!.SortString;
            sortDirection = request.Sorting.FirstOrDefault()!.SortDirection == SortDirection.Ascending ? ListSortDirection.Ascending : ListSortDirection.Descending;
        }

        var result = await infrastructureService.GetInfrastructureItemBySearchParameters(
                RouteId,
                ParishIds,
                ParishId,
                MaintenanceTeamId,
                InfrastructureTypeId,
                InstallationDateFrom,
                InstallationDateTo,
                sortString,
                sortDirection,
                request.PageNumber,
                request.PageSize, request.CancellationToken);

        return await Task.FromResult(new GridDataProviderResult<InfrastructureItem> { Data = result.Results, TotalCount = result.TotalResults });
    }


    private void OnRowClick(GridRowEventArgs<InfrastructureItem> args) => navigationManager.NavigateTo($"Infrastructure/Details/{args.Item.Id}");
}
