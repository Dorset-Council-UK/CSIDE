@using CSIDE.Data.Models.Shared
@using CSIDE.Data.Services
@using System.Globalization
@inject ISharedDataService sharedDataService
@inject IJSRuntime JS
@inject ILogger<MediaItem> logger

@if (Media is not null)
{
    @if(Media.Format == MediaType.Image)
    {
        <div class="card my-2 bg-light">
            <a href="@GetImageUrlWithCacheBuster()" class="blueimp-img">
                <img src="@GetImageUrlWithCacheBuster()" class="img-fluid" style="@(_isRotating ? "opacity: 0.5;" : "")" />
            </a>
            <div class="card-body">
                @if (IsEditable)
                {
                    <button type="button" class="btn btn-sm btn-outline-danger me-2" @onclick="DeleteMedia" disabled="@_isRotating"><i class="bi bi-trash"></i> @localizer["Delete Label"]</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary me-2" title="@localizer["Rotate Counter Clockwise Label"]" @onclick="() => RotateImage(-90)" disabled="@_isRotating">
                        <i class="bi bi-arrow-counterclockwise"></i>
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary me-2" title="@localizer["Rotate Clockwise Label"]" @onclick="() => RotateImage(90)" disabled="@_isRotating">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                }
                <a href="@Media.URL" download target="_blank" class="btn btn-sm btn-outline-secondary me-2" title="@localizer["Download Label"]"><i class="bi bi-cloud-arrow-down"></i></a>
                <div class="mt-2 pt-2 border-1 border-top">
                    @if (!string.IsNullOrEmpty(Media.Title))
                    {
                        <p>@Media.Title</p>
                    }
                    <small><strong>@localizer["Upload Date Label"]:</strong> @(Media.UploadDate.HasValue ? Media.UploadDate.Value.InZone(DateTimeZoneProviders.Tzdb.GetSystemDefault()).LocalDateTime.ToString("dd/MM/yyyy HH:mm", CultureInfo.CurrentCulture) : "Unknown")</small>
                </div>
            </div>
        </div>
    }
    else if(Media.Format == MediaType.Video)
    {
        <div class="card">
            <div class="card-body">
                <video src="@Media.URL" class="my-2" style="max-width:100%;height:300px;max-height:80vh" controls preload="metadata"></video>
                <div class="my-2">
                    @if (IsEditable)
                    {
                        <button type="button" class="btn btn-sm btn-outline-danger me-2" @onclick="DeleteMedia"><i class="bi bi-trash"></i> @localizer["Delete Label"]</button>
                    }
                    <a href="@Media.URL" download target="_blank" class="btn btn-sm btn-outline-secondary me-2" title="@localizer["Download Label"]"><i class="bi bi-cloud-arrow-down"></i></a>

                    <div class="mt-2 pt-2 border-1 border-top">
                        @if (!string.IsNullOrEmpty(Media.Title))
                        {
                            <p>@Media.Title</p>
                        }
                        <small><strong>@localizer["Upload Date Label"]:</strong> @(Media.UploadDate.HasValue ? Media.UploadDate.Value.InZone(DateTimeZoneProviders.Tzdb.GetSystemDefault()).LocalDateTime.ToString("dd/MM/yyyy HH:mm", CultureInfo.CurrentCulture) : "Unknown")</small>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {

        var icon = "bi-fil-earmark";
        if(Media.Format == MediaType.Word_Document)
        {
            icon = "bi-filetype-docx";
        }else if(Media.Format == MediaType.Excel_Spreadsheet)
        {
            icon = "bi-filetype-xlsx";
        }else if(Media.Format == MediaType.PDF_Document)
        {
            icon = "bi-filetype-pdf";
        }

        <tr>

            <td>
                <a href="@Media.URL" download target="_blank"><i class="bi @icon"></i> 
                    @(string.IsNullOrEmpty(Media.Title) ? new System.IO.FileInfo(Media.URL).Name : Media.Title)
                </a>
            </td>
            <td>@(Media.UploadDate.HasValue ? Media.UploadDate.Value.InZone(DateTimeZoneProviders.Tzdb.GetSystemDefault()).LocalDateTime.ToString("dd/MM/yyyy HH:mm", CultureInfo.CurrentCulture) : "Unknown")</td>
            @if (IsEditable)
            {
                <td> <button type="button" class="btn btn-sm btn-outline-danger" @onclick="DeleteMedia"><i class="bi bi-trash"></i> @localizer["Delete Label"]</button></td>
            }

        </tr>
    }

}
@code{
    [Parameter]
    public required Media Media { get; set; }
    [Parameter]
    public bool IsEditable { get; set; }
    [Parameter]
    public EventCallback OnRefreshComponent{ get; set; }

    private long _cacheBuster = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
    private bool _isRotating = false;

    private string GetImageUrlWithCacheBuster()
    {
        if (Media?.URL == null) return string.Empty;
        
        var separator = Media.URL.Contains('?') ? "&" : "?";
        return $"{Media.URL}{separator}v={_cacheBuster}";
    }

    private async Task DeleteMedia()
    {
        bool ConfirmDelete = await JS.InvokeAsync<bool>("confirm", localizer["Delete Media Confirmation"].Value);
        if (ConfirmDelete)
        {
            try
            {
                await sharedDataService.DeleteMediaItem(Media.Id);

                if (OnRefreshComponent.HasDelegate)
                {
                    await OnRefreshComponent.InvokeAsync();
                }
                
            }
            catch(Exception ex)
            {
                logger.LogError(ex, "An error occurred deleting a media item");
            }
        }
    }

    private async Task RotateImage(int degrees)
    {
        _isRotating = true;
        StateHasChanged();
        
        try
        {
            var success = await sharedDataService.RotateMediaImage(Media.Id, degrees);
            
            if (success)
            {
                // Update cache buster to force image reload
                _cacheBuster = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
                
                // Refresh the component to show the rotated image
                if (OnRefreshComponent.HasDelegate)
                {
                    await OnRefreshComponent.InvokeAsync();
                }
            }
            else
            {
                logger.LogWarning("Failed to rotate image for media item {MediaId}", Media.Id);
                await JS.InvokeVoidAsync("alert", "Failed to rotate image. Please try again.");
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "An error occurred rotating a media item");
            await JS.InvokeVoidAsync("alert", "An error occurred while rotating the image. Please try again.");
        }
        finally
        {
            _isRotating = false;
            StateHasChanged();
        }
    }
}
