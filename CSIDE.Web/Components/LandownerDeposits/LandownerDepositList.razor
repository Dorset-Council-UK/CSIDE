@rendermode InteractiveServer
@using CSIDE.Data.Models.LandownerDeposits
@using CSIDE.Data.Services
@using NodaTime
@using System.Globalization
@using System.ComponentModel
@inject NavigationManager navigationManager
@inject ILandownerDepositService landownerDepositService

<a href="landowner-deposits#search-form">@localizer["Search Again Label"]</a>


<Grid TItem="LandownerDeposit"
      Class="table table-hover table-bordered table-striped mt-2"
      DataProvider="LandownerDepositDataProvider"
      AllowFiltering="false"
      AllowPaging="true"
      PageSize="20"
      AllowSorting="true"
      AllowSelection="false"
      AllowRowClick="true"
      OnRowClick="OnRowClick"
      AutoHidePaging="true"
      Responsive="true">

    <GridColumns>
        <GridColumn TItem="LandownerDeposit" Filterable="false" HeaderText="@localizer["Landowner Deposit ID Label"]" PropertyName="Id" SortKeySelector="item => item.Id" SortString="Id">
            <a href="landowner-deposits/Details/@context.Id/@context.SecondaryId" @onclick:stopPropagation>@IDPrefixOptions.Value.LandownerDeposit@context.Id/@context.SecondaryId</a>
        </GridColumn>
        <GridColumn TItem="LandownerDeposit" Filterable="false" HeaderText="@localizer["Landowner Deposit Type Label"]" PropertyName="LandownerDepositTypes">
            @foreach (var landownerDepositType in context.LandownerDepositTypes)
            {
                <p>@landownerDepositType.LandownerDepositTypeName?.Name</p>
            }
        </GridColumn>
        <GridColumn TItem="LandownerDeposit" Filterable="false" HeaderText="@localizer["Landowner Deposit Date Received Label"]" PropertyName="ReceivedDate" SortKeySelector="item => item.ReceivedDate" SortString="ReceivedDate">
            @(context.ReceivedDate.HasValue? context.ReceivedDate.Value.ToString("dd/MM/yyyy", CultureInfo.CurrentCulture) : "Unknown")
        </GridColumn>
        <GridColumn TItem="LandownerDeposit" Filterable="false" Class="comment-field" Sortable="false" HeaderText="@localizer["Landowner Deposit Location Label"]" PropertyName="Location">
            @if (context.Location?.Length > 200)
            {
                @context.Location?.Substring(0, 200)
            
                <text>&hellip;</text>
            }
            else
            {
                @context.Location
            }
        </GridColumn>
        <GridColumn TItem="LandownerDeposit" Filterable="false" Sortable="false" HeaderText="@localizer["Parish Label"]" PropertyName="LandownerDepositParishes" SortKeySelector="@(item => item.LandownerDepositParishes != null ? string.Join(", ", item.LandownerDepositParishes.Select(p => p.Parish.Name)) : string.Empty)" SortString="Parish">
            @string.Join(", ", context.LandownerDepositParishes.Select(p => p.Parish.Name))
        </GridColumn>
    </GridColumns>
    <GridTemplates>
        <GridEmptyDataTemplate TItem="LandownerDeposit">
            <div class="text-center text-muted">
                <span class="bi bi-inbox fs-2"></span>
                <div>
                    <p>@localizer["No Results Found Label"]</p>
                    <p><a href="landowner-deposits#search-form">@localizer["Search Again Label"]</a></p>
                </div>
            </div>
        </GridEmptyDataTemplate>
    </GridTemplates>
</Grid>


@code {
    [Parameter]
    public string[]? ParishIds { get; set; }
    [Parameter]
    public string? ParishId { get; set; }
    [Parameter]
    public string? Location { get; set; }

    public async Task<GridDataProviderResult<LandownerDeposit>> LandownerDepositDataProvider(GridDataProviderRequest<LandownerDeposit> request)
    {
        //handle sorting
        string sortString = "";
        ListSortDirection sortDirection = ListSortDirection.Ascending;
        if (request.Sorting is not null && request.Sorting.Any())
        {
            // Note: Multi column sorting is not supported at this moment
            sortString = request.Sorting.FirstOrDefault()!.SortString;
            sortDirection = request.Sorting.FirstOrDefault()!.SortDirection == SortDirection.Ascending ? ListSortDirection.Ascending : ListSortDirection.Descending;
        }

        var result = await landownerDepositService.GetLandownerDepositsBySearchParameters(
                ParishIds,
                ParishId,
                Location,
                sortString,
                sortDirection,
                request.PageNumber,
                request.PageSize, request.CancellationToken);

        return await Task.FromResult(new GridDataProviderResult<LandownerDeposit> { Data = result.Results, TotalCount = result.TotalResults });
    }

    private void OnRowClick(GridRowEventArgs<LandownerDeposit> args) => navigationManager.NavigateTo($"landowner-deposits/Details/{args.Item.Id}/{args.Item.SecondaryId}");
}