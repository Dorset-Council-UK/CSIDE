@using CSIDE.Data.Models.RightsOfWay
@using CSIDE.Data.Models.Shared
@using System.Globalization

@if(Route is not null)
{
    
    @if (Route.RouteMedia is not null && Route.RouteMedia.Count != 0)
    {
        
        var images = from m in Route.RouteMedia where m.Media.Format == MediaType.Image select m;
        var videos = from m in Route.RouteMedia where m.Media.Format == MediaType.Video select m;
        var routeClosureDocs = from m in Route.RouteMedia where m.IsClosureNotificationDocument == true select m;
        var docs = 
            from m in Route.RouteMedia
            where (
                (m.Media.Format == MediaType.PDF_Document | 
                m.Media.Format == MediaType.Word_Document |
                m.Media.Format == MediaType.Excel_Spreadsheet |
                m.Media.Format == MediaType.Unknown) && m.IsClosureNotificationDocument == false)
            select m;

        if (routeClosureDocs.Count() != 0 || (Route.OperationalStatus is not null && Route.OperationalStatus.IsClosed))
        {
            <div class="row my-4">
                <h4>@localizer["Route Closure Documents Label"]</h4>
                <div class="col">
                    @if(routeClosureDocs.Count() == 0){
                        <Alert Color="AlertColor.Info">@localizer["No Route Closure Documents Message"]</Alert>
                    }else{
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <tbody>
                                    @foreach (RouteMedia routeMediaItem in routeClosureDocs.OrderByDescending(i => i.Media.UploadDate))
                                    {
                                        <MediaItem Media="@routeMediaItem.Media" IsEditable="@IsEditable" OnRefreshComponent="RefreshComponent"></MediaItem>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                </div>
            </div>
            <hr/>
        }

        if (docs.Count() != 0)
        {
            <div class="row my-4">
                <h4>@localizer["Documents Label"]</h4>
                <div class="col">
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <tbody>
                                @foreach (RouteMedia routeMediaItem in docs.OrderByDescending(i => i.Media.UploadDate))
                                {
                                    <MediaItem Media="@routeMediaItem.Media" IsEditable="@IsEditable" OnRefreshComponent="RefreshComponent"></MediaItem>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        if (images.Count() != 0)
        {
            <div class="row my-4">
                <h4>@localizer["Images Label"]</h4>
                <div id="media-gallery">
                    @foreach (RouteMedia routeMediaItem in images.OrderByDescending(i => i.Media.UploadDate))
                    {
                        <MediaItem Media="@routeMediaItem.Media" IsEditable="@IsEditable" OnRefreshComponent="RefreshComponent"></MediaItem>
                    }
                </div>
                
            </div>
            <hr/>
        }
        if (videos.Count() != 0)
        {
            <div class="row my-4">
                <h4>@localizer["Videos Label"]</h4>
                @foreach (RouteMedia routeMediaItem in videos.OrderByDescending(i => i.Media.UploadDate))
                {
                    <div class="col-12">
                        <MediaItem Media="@routeMediaItem.Media" IsEditable="@IsEditable" OnRefreshComponent="RefreshComponent"></MediaItem>
                    </div>
                }
            </div>
            <hr />
        }
    }
    else
    {
        <Alert Color="AlertColor.Info">@localizer["No Media Message"]</Alert>
    }
}

@if (IsEditable)
{
    if (Route is not null && (Route.OperationalStatus is not null && Route.OperationalStatus.IsClosed))
    {
        <UploadFile MaxAllowedFiles="5"
                    MaxFileSizeMB="10"
                    OnUploadComplete="@AddRouteClosureMediaToRoute"
                    Title="@localizer["Upload Closure Notification Document Title"]">
        </UploadFile>
        <hr/>
    }
    <UploadFile 
        MaxAllowedFiles="10" 
        MaxFileSizeMB="50" 
        OnUploadComplete="@AddMediaToRoute" 
        Title="@localizer["Upload Other Media Title"]">
    </UploadFile>
}

<!--lightbox-->
<div id="blueimp-gallery"
class="blueimp-gallery blueimp-gallery-controls"
aria-label="image gallery"
aria-modal="true"
role="dialog">
    <div class="slides" aria-live="polite"></div>
    <h3 class="title"></h3>
    <a class="prev"
    aria-controls="blueimp-gallery"
    aria-label="previous slide"
    aria-keyshortcuts="ArrowLeft"></a>
    <a class="next"
    aria-controls="blueimp-gallery"
    aria-label="next slide"
    aria-keyshortcuts="ArrowRight"></a>
    <a class="close"
    aria-controls="blueimp-gallery"
    aria-label="close"
    aria-keyshortcuts="Escape"></a>
    <a class="play-pause"
    aria-controls="blueimp-gallery"
    aria-label="play slideshow"
    aria-keyshortcuts="Space"
    aria-pressed="false"
    role="button"></a>
    <ol class="indicator"></ol>
</div>

